# Auto detect text files and normalize line endings to LF
* text=auto

# Dart files
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.wav binary
*.mp3 binary
*.aac binary
*.ogg binary

# Gradle
*.gradle text eol=lf
*.gradle.kts text eol=lf

# Shell scripts
*.sh text eol=lf
